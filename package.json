{
  "name": "zenstyle",
  "version": "1.0.0",
  "description": "Framework CSS léger, responsive, personnalisable et accessible.",
  "type": "module",
  "main": "zenstyle.js",
  "style": "zenstyle.css",
  "files": [
    "zenstyle.css",
    "zenstyle.js",
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "start": "node scripts/server.mjs",
    "build": "node scripts/build.mjs",
    "check": "node scripts/check-framework.mjs",
    "prepack": "npm run build && npm run check",
    "test": "playwright test",
    "test:headed": "playwright test --headed",
    "test:install": "playwright install"
  },
  "keywords": [
    "css",
    "framework",
    "zenstyle",
    "html",
    "responsive",
    "accessible",
    "design-system"
  ],
  "license": "MIT",
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@playwright/test": "^1.60.0",
    "esbuild": "^0.28.1",
    "lightningcss": "^1.32.0"
  }
}
